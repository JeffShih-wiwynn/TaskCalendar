:80 {
  root * /srv
  encode zstd gzip

  handle /api/* {
    reverse_proxy backend:8000
  }

  handle /auth/* {
    reverse_proxy backend:8000
  }

  handle /backup/* {
    reverse_proxy backend:8000
  }

  handle /health {
    reverse_proxy backend:8000
  }

  try_files {path} /index.html
  file_server
}
